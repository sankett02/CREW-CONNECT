generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String
  role                 Role
  isVerified           Boolean         @default(false)
  isFlagged            Boolean         @default(false)
  otp                  String?
  otpExpires           DateTime?
  stripeAccountId      String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  applications         Application[]
  messages             Message[]
  payments             PaymentRecord[]
  profile              Profile?
  projects             Project[]       @relation("BrandProjects")
  ratingsReceived      Rating[]        @relation("Reviewee")
  ratingsGiven         Rating[]        @relation("Reviewer")
  teamMemberAt         TeamMember[]
  activities           ProjectActivity[]
}

model Profile {
  id               String  @id @default(uuid())
  userId           String  @unique
  displayName      String
  bio              String?
  category         String?
  nicheTags        String?
  skills           String?
  portfolioLinks   String?
  socialLinks      String?
  contactNumber    String?
  profileImage     String?
  ratingAvg        Float   @default(0.0)
  completedCount   Int     @default(0)
  companyName      String?
  brandType        String?
  websiteUrl       String?
  portfolioUrl     String?
  hourlyRate       Float?
  originalityScore Int     @default(98)
  totalReach       Int     @default(0)
  growthRate       Float   @default(0.0)
  successRate      Int     @default(100)
  user             User    @relation(fields: [userId], references: [id])
}

model Project {
  id             String          @id @default(uuid())
  brandId        String
  title          String
  description    String
  niche          String
  budget         Decimal
  totalBrandCost Decimal         @default(0)
  creatorPayout  Decimal         @default(0)
  deadline       DateTime
  status         ProjectStatus   @default(DRAFT)
  isFlagged      Boolean         @default(false)
  openSlots      String          @default("[]")
  createdAt      DateTime        @default(now())
  completedAt    DateTime?
  applications   Application[]
  disputes       Dispute[]
  messages       Message[]
  milestones     Milestone[]
  payments       PaymentRecord[]
  brand          User            @relation("BrandProjects", fields: [brandId], references: [id])
  ratings        Rating[]
  team           TeamMember[]
  activities     ProjectActivity[]
}

model Application {
  id          String   @id @default(uuid())
  projectId   String
  creatorId   String
  status      String   @default("PENDING")
  type        String   @default("APPLICATION")
  appliedRole String?
  message     String?
  createdAt   DateTime @default(now())
  creator     User     @relation(fields: [creatorId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
}

model TeamMember {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  role      String
  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  projectId  String
  senderId   String
  content    String
  isTeamOnly Boolean  @default(false)
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())
  sender         User     @relation(fields: [senderId], references: [id])
  project        Project  @relation(fields: [projectId], references: [id])
}

model ProjectActivity {
  id        String   @id @default(uuid())
  projectId String
  userId    String?
  type      String   // e.g., "MILESTONE_UPDATED", "FILE_UPLOADED", "MESSAGE_SENT"
  content   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
}

model Milestone {
  id            String          @id @default(uuid())
  projectId     String
  title         String
  assignedRole  String?
  status        MilestoneStatus @default(DRAFT)
  escrowFunded  Boolean         @default(false)
  comments      String?
  submissionUrl String?
  feedback      String?
  submittedAt   DateTime?
  updatedAt     DateTime        @updatedAt
  project       Project         @relation(fields: [projectId], references: [id])
  payments      PaymentRecord[]
}

model Rating {
  id         String  @id @default(uuid())
  projectId  String
  reviewerId String
  revieweeId String
  score      Int
  review     String?
  reviewee   User    @relation("Reviewee", fields: [revieweeId], references: [id])
  reviewer   User    @relation("Reviewer", fields: [reviewerId], references: [id])
  project    Project @relation(fields: [projectId], references: [id])
}

model Dispute {
  id        String  @id @default(uuid())
  projectId String
  parties   Json
  notes     String
  status    String  @default("OPEN")
  project   Project @relation(fields: [projectId], references: [id])
}

model PaymentRecord {
  id            String     @id @default(uuid())
  projectId     String
  amount        Decimal
  payerId       String
  milestoneId   String?
  payoutSplit   Json
  platformFee   Decimal    @default(0)
  processingFee Decimal    @default(0)
  status        String     @default("PENDING")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  milestone     Milestone? @relation(fields: [milestoneId], references: [id])
  payer         User       @relation(fields: [payerId], references: [id])
  project       Project    @relation(fields: [projectId], references: [id])
}

enum Role {
  BRAND
  CREATOR
  CREATOR_LEAD
  WRITER
  EDITOR
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  DRAFT
  PENDING
  TEAM_REVIEW
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
}
